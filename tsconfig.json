{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "node" /* Changed from 'Bundler' to 'node' */,
    "rootDir": "./src",
    "outDir": "./dist",
    "noEmit": false /* Changed to false to allow generation */,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}
