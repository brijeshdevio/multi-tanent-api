{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "typeRoots": ["./node_modules/@types"],
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "bundler", // Best for Bun/modern bundlers
    "allowSyntheticDefaultImports": true, // Fixes the Express import error
    "esModuleInterop": true, // Also helps with CommonJS/ESM interop
    "skipLibCheck": true
  },
  "include": ["src"]
}
